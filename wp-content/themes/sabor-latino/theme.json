{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "color": "#1A0500", "name": "Base",       "slug": "base" },
        { "color": "#FFF8F0", "name": "Default",    "slug": "default" },
        { "color": "#C0392B", "name": "Primary",    "slug": "primary" },
        { "color": "#0D0300", "name": "Secondary",  "slug": "secondary" },
        { "color": "#F5ECD7", "name": "Tertiary",   "slug": "tertiary" },
        { "color": "#E8DCC8", "name": "Quaternary", "slug": "quaternary" },
        { "color": "#FFF8F0", "name": "Quinary",    "slug": "quinary" },
        { "color": "#E67E22", "name": "Accent",     "slug": "accent" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Playfair Display', Georgia, serif",
          "name": "Playfair Display",
          "slug": "playfair",
          "fontFace": [{ "fontFamily": "Playfair Display", "fontStyle": "normal", "fontWeight": "400 700", "src": ["https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&display=swap"] }]
        },
        {
          "fontFamily": "'Lato', system-ui, sans-serif",
          "name": "Lato",
          "slug": "lato",
          "fontFace": [{ "fontFamily": "Lato", "fontStyle": "normal", "fontWeight": "400 700", "src": ["https://fonts.googleapis.com/css2?family=Lato:wght@400;700&display=swap"] }]
        }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--lato)",
      "fontSize": "var(--wp--preset--font-size--medium)"
    },
    "color": {
      "background": "var(--wp--preset--color--default)",
      "text": "var(--wp--preset--color--base)"
    },
    "elements": {
      "heading": {
        "typography": { "fontFamily": "var(--wp--preset--font-family--playfair)" },
        "color": { "text": "var(--wp--preset--color--base)" }
      },
      "button": {
        "color": { "background": "var(--wp--preset--color--primary)", "text": "var(--wp--preset--color--default)" },
        "typography": { "fontFamily": "var(--wp--preset--font-family--lato)", "fontWeight": "700" },
        ":hover": { "color": { "background": "var(--wp--preset--color--accent)" } }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--accent)" } }
      }
    }
  }
}
