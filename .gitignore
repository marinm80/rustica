# ==========================================
# 1. DOCKER & CONFIGURACIONES SENSIBLES
# ==========================================
# Ignorar los archivos binarios de la base de datos (¡Crítico!)
db_data/
mysql_data/

# Ignorar credenciales y contraseñas locales
.env
.env.production
.env.staging
wp-config.php

# ==========================================
# 2. WORDPRESS (ARCHIVOS DINÁMICOS Y PESADOS)
# ==========================================
# NUNCA subas las imágenes o PDFs que subes a la web (ocupan gigabytes)
**/wp-content/uploads/

# Ignorar archivos temporales, cachés y copias de seguridad de WordPress
**/wp-content/cache/
**/wp-content/backups/
**/wp-content/upgrade/
**/*.log

# ==========================================
# 3. SISTEMA OPERATIVO E IDEs (LIMPIEZA)
# ==========================================
# Archivos basura de Windows y Mac
.DS_Store
Thumbs.db
ehthumbs.db

# Configuraciones de editores de código
.vscode/
.idea/
.project

# ==========================================
# 4. NODE / BUILD
# ==========================================
node_modules/
dist/
**/wp-content/plugins/rustica-system/frontend/node_modules/
**/wp-content/plugins/rustica-system/frontend/dist/

# ==========================================
# 5. LANDING PAGE (RUSTICA FRONTEND)
# ==========================================
src/dist/
coverage/
playwright-report/
test-results/
*.tsbuildinfo
